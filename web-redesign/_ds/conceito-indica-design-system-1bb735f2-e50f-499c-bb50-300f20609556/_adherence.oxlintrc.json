{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/core/**",
              "components/icons/**",
              "components/navigation/**",
              "components/surfaces/**",
              "ui_kits/atendimento/**",
              "ui_kits/relatorios/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Hanken Grotesk))/i]",
        "message": "Font not provided by the design system. Available: Hanken Grotesk."
      },
      {
        "selector": "JSXOpeningElement[name.name='AnimIcon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|play|key|ref|className|style|children)$/]",
        "message": "<AnimIcon> doesn't accept that prop. Declared props: name, size, strokeWidth, play."
      },
      {
        "selector": "JSXOpeningElement[name.name='AnimIcon'] > JSXAttribute[name.name='name'] > Literal[value!=/^(?:vendas|relatorios|compras|financeiro|estoque|entregas|crediario|ecommerce|metas|recebiveis|sngpc|atendimento|orcamentos|historico|campanhas|fidelizacao|treinamento|dashboard|multiloja|transferencias|cadastros|fiscal|fat|lucro|margem|alert|contas)$/]",
        "message": "<AnimIcon> name must be one of 'vendas' | 'relatorios' | 'compras' | 'financeiro' | 'estoque' | 'entregas' | 'crediario' | 'ecommerce' | 'metas' | 'recebiveis' | 'sngpc' | 'atendimento' | 'orcamentos' | 'historico' | 'campanhas' | 'fidelizacao' | 'treinamento' | 'dashboard' | 'multiloja' | 'transferencias' | 'cadastros' | 'fiscal' | 'fat' | 'lucro' | 'margem' | 'alert' | 'contas'."
      },
      {
        "selector": "JSXOpeningElement[name.name='AnimIcon'] > JSXAttribute[name.name='play'] > Literal[value!=/^(?:hover|always|none)$/]",
        "message": "<AnimIcon> play must be one of 'hover' | 'always' | 'none'."
      },
      {
        "selector": "JSXOpeningElement[name.name='AskAIBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|suggestions|placeholderMode|interval|orb|onSend|key|ref|className|style|children)$/]",
        "message": "<AskAIBar> doesn't accept that prop. Declared props: label, suggestions, placeholderMode, interval, orb, onSend."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:initials|tone|size|square|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: initials, tone, size, square."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:pink|brand|neutral)$/]",
        "message": "<Avatar> tone must be one of 'pink' | 'brand' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Avatar> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|dot|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, dot, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:brand|pos|warn|neg|muted|solid)$/]",
        "message": "<Badge> tone must be one of 'brand' | 'pos' | 'warn' | 'neg' | 'muted' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|block|icon|iconRight|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, block, icon, iconRight, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|brand|secondary|ghost|destructive)$/]",
        "message": "<Button> variant must be one of 'primary' | 'brand' | 'secondary' | 'ghost' | 'destructive'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subtitle|action|onAction|pad|hover|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: title, subtitle, action, onAction, pad, hover, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='pad'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Card> pad must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|active|icon|children|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: variant, active, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:search|complement|plain)$/]",
        "message": "<Chip> variant must be one of 'search' | 'complement' | 'plain'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KpiCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|icon|value|delta|direction|spark|sparkColor|alert|flush|key|ref|className|style|children)$/]",
        "message": "<KpiCard> doesn't accept that prop. Declared props: label, icon, value, delta, direction, spark, sparkColor, alert, flush."
      },
      {
        "selector": "JSXOpeningElement[name.name='KpiCard'] > JSXAttribute[name.name='direction'] > Literal[value!=/^(?:up|down|flat)$/]",
        "message": "<KpiCard> direction must be one of 'up' | 'down' | 'flat'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavRailItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|icon|dot|key|ref|className|style|children)$/]",
        "message": "<NavRailItem> doesn't accept that prop. Declared props: id, label, icon, dot."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|key|ref|className|style|children)$/]",
        "message": "<SegmentOption> doesn't accept that prop. Declared props: value, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusDot'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|halo|size|key|ref|className|style|children)$/]",
        "message": "<StatusDot> doesn't accept that prop. Declared props: tone, halo, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusDot'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:pos|warn|neg)$/]",
        "message": "<StatusDot> tone must be one of 'pos' | 'warn' | 'neg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ThemeToggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:target|storageKey|key|ref|className|style|children)$/]",
        "message": "<ThemeToggle> doesn't accept that prop. Declared props: target, storageKey."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrendPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:direction|icon|children|key|ref|className|style|children)$/]",
        "message": "<TrendPill> doesn't accept that prop. Declared props: direction, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrendPill'] > JSXAttribute[name.name='direction'] > Literal[value!=/^(?:up|down|flat)$/]",
        "message": "<TrendPill> direction must be one of 'up' | 'down' | 'flat'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
